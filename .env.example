# Copiá este archivo a `.env` y completá con tus claves reales.
# El archivo .env está en .gitignore — nunca se sube al repo.

# Google AI Studio (Gemini)
# Conseguí tu key en https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_clave_aca

# Modelo por defecto para clasificación, resumen, extracción de entidades.
GEMINI_FAST_MODEL=gemini-2.0-flash

# Modelo para generación de respuesta sugerida (mayor calidad).
GEMINI_QUALITY_MODEL=gemini-2.5-pro

# (Opcional) Ruta local del vector store Chroma.
CHROMA_PERSIST_DIR=./data/chroma
