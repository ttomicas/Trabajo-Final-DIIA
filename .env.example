# Copiá este archivo a `.env` y completá con tus claves reales.
# El archivo .env está en .gitignore — nunca se sube al repo.

# Google AI Studio (Gemini)
# Conseguí tu key en https://aistudio.google.com/app/apikey
GOOGLE_API_KEY=tu_clave_aca

# Modelo por defecto: 2.5 Flash Lite tiene cuota diaria de 1000 RPD en
# free tier (vs 20 RPD del Flash a secas), ideal para PoC sin billing.
GEMINI_FAST_MODEL=gemini-2.5-flash-lite

# Modelo de calidad para respuestas sugeridas. Sigue siendo Flash a secas
# porque Pro tiene cuota muy ajustada en free tier.
GEMINI_QUALITY_MODEL=gemini-2.5-flash-lite

# (Opcional) Ruta local del vector store Chroma.
CHROMA_PERSIST_DIR=./data/chroma
